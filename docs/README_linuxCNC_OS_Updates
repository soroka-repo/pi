###STEP: Install ssh
###################################
 sudo apt update
 sudo apt install openssh-server
 systemctl status ssh
 systemctl start ssh   ### to start ssh 
 systemctl enable ssh   ### to enable ssh starting at boot

###################################
###STEP: Install ufw firewall
###################################
 sudo apt update
 sudo apt install ufw
 sudo ufw allow ssh  ### to allow ssh
 sudo ufw allow vnc  ### to allow vnc
 sudo ufw status numbered ### numbered adds the number of the rule which can be used to delete the rule
 sudo ufw delete 4 ### deletes rule numbered 4
 sudo ufw status verbose ### shows the default rules too

