###################################
###STEP: Increase the paging swap space 
#################################
# lets add 32g of swap space patched in so you have to have the space on you NVME
# if not you will need to use gpartd to reduce the / file system the ideal way to do 
# this would be to boot off a microSD card and move the swap space before the / root
# file system

# View what we have now
 free -h
 swapon --show
# NOTE: on the Jetson Orin Nano Super we disable the ZRAM on the PI we will leave it active
# create the swapfile
 sudo fallocate -l 32G /swapfile
# set premisssions
 sudo chmod 600 /swapfile
# setup swap area
 sudo mkswap /swapfile
# Enable the swap
 sudo swapon /swapfile
# Make it survive a reboot
 cat /etc/fstab # this is what you are starting with
 sudo cp /etc/fstab /etc/fstab.bak # backing it up in case you make a mistake
 sudo echo '/swapfile none swap sw,pri=10 0 0'|sudo tee -a /etc/fstab # add a line
 cat /etc/fstab # this should be what you started with plus the line added above
# view what we have now
 free -h
 swapon --show

###EXAMPLE: swapon --show
NAME           TYPE      SIZE USED PRIO
/dev/zram0     partition   2G   0B  100
/dev/nvme0n1p3 partition  32G   0B   10
###EXAMPLE_END:

# NOTE: the PRIO zram should be higher (100) then the NVME (10) swapfiles

